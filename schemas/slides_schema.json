{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maverx Slides",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["slide_number", "slide_type", "block", "level", "title", "body", "table", "visual_suggestion", "confidence_score", "confidence_reason", "speaker_notes"],
    "properties": {
      "slide_number": { "type": "integer", "minimum": 1 },
      "slide_type": {
        "type": "string",
        "enum": [
          "kickoff_title",
          "kickoff_agenda",
          "kickoff_objectives",
          "mentimeter_recap",
          "theory_intro",
          "theory_deep",
          "example_walkthrough",
          "example_case",
          "exercise_setup",
          "exercise_instructions",
          "wrapup_summary",
          "wrapup_nextlevel"
        ]
      },
      "block": {
        "enum": ["kick-off", "theory", "example", "exercise", "wrap-up"]
      },
      "level": { "type": "integer", "enum": [1, 2, 3] },
      "title": { "type": "string" },
      "body": { "type": "array", "items": { "type": "string" } },
      "table": {
        "type": ["object", "null"],
        "properties": {
          "headers": { "type": "array", "items": { "type": "string" } },
          "rows": { "type": "array", "items": { "type": "array" } }
        }
      },
      "visual_suggestion": {
        "type": "string",
        "minLength": 1
      },
      "confidence_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "confidence_reason": {
        "type": "string",
        "minLength": 1
      },
      "speaker_notes": {
        "type": "object",
        "required": ["aim", "time", "instructions", "reflective_question", "debrief", "key_discussion_points", "link_to_reality"],
        "properties": {
          "aim": { "type": "string" },
          "time": { "type": "string" },
          "instructions": { "type": "string" },
          "reflective_question": { "type": "string" },
          "debrief": { "type": "string" },
          "key_discussion_points": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "link_to_reality": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
